                    createdAt: new Date(Date.now() - 43200000).toISOString()
                },
                {
                    id: '103',
                    userId: '3',
                    imageUrl: 'https://picsum.photos/600/600?random=3',
                    caption: 'Exploring ancient temples #travel #adventure #history',
                    location: 'Angkor Wat, Cambodia',
                    likes: ['1', '2'],
                    comments: [
                        {
                            id: 'c2',
